<UserControl x:Class="ClassToolkit.Core.Controls.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="40">

    <Border x:Name="TitleBarBorder"
            Background="{DynamicResource TitleBarBackground}"
            MouseLeftButtonDown="OnDrag">
        <Grid>
            <TextBlock x:Name="TitleText"
                       VerticalAlignment="Center" Margin="12,0,0,1"
                       FontFamily="Microsoft YaHei UI" FontSize="14"
                       Foreground="{DynamicResource TextPrimary}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnMinimize"
                        Width="46" Height="40"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondary}"
                        FontSize="16" FontFamily="Microsoft YaHei UI" Cursor="Hand"
                        Click="OnMinimize" Content="─" ToolTip="最小化"/>
                <Button x:Name="BtnClose"
                        Width="46" Height="40"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondary}"
                        FontSize="16" FontFamily="Microsoft YaHei UI" Cursor="Hand"
                        Click="OnClose" Content="✕" ToolTip="关闭"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
