<Window x:Class="ClassToolkit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="60" Width="60"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        MouseLeftButtonDown="ClickBall"
        MouseLeftButtonUp="LeftClickUp"
        MouseMove="OnDragFloatBall"
        Loaded="Window_Loaded">
    
    <Grid>
        <Ellipse Fill="#EF121212"
                 Stroke="White"
                 StrokeThickness="1"/>
        <!-- 菜单容器 -->
        <Border x:Name="Menu"
                Width="80" Height="200"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#EF121212"
                RenderTransformOrigin="0.5,0.5"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform X="-200"/>   <!-- 初始偏移左侧外 -->
            </Border.RenderTransform>
            
            
        </Border>
        
    </Grid>
</Window>
